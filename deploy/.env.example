# ============================================================
# Supabase 自托管 环境变量
# 复制为 .env 后填入实际值: cp .env.example .env
# ⚠️ .env 不要提交到 git
# ============================================================

# ---- 数据库 ----
POSTGRES_PASSWORD=your-super-secret-db-password
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# ---- JWT（所有服务共享） ----
# 生成方式: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-token-at-least-32-characters
JWT_EXPIRY=3600

# ---- API Keys ----
# 用 https://supabase.com/docs/guides/self-hosting#api-keys 生成
# 或用 supabase CLI: supabase status 查看本地 key 格式
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---- 外部访问 URL ----
# 服务器实际地址，老师部署时修改
API_EXTERNAL_URL=http://localhost:8000
SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=http://localhost:3000

# ---- Studio ----
STUDIO_PORT=3000
STUDIO_DEFAULT_ORGANIZATION=曙光医院
STUDIO_DEFAULT_PROJECT=shuguang-his

# ---- PostgREST ----
PGRST_DB_SCHEMAS=public,graphql_public
PGRST_DB_EXTRA_SEARCH_PATH=public,extensions
MAX_ROWS=1000

# ---- Realtime ----
# 生成方式: openssl rand -base64 48
SECRET_KEY_BASE=your-secret-key-base-at-least-64-characters

# ---- Auth ----
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true

# ---- SMTP（生产环境配置真实 SMTP） ----
SMTP_HOST=inbucket
SMTP_PORT=2500
SMTP_ADMIN_EMAIL=admin@email.com
SMTP_SENDER_NAME=Admin

# ---- Inbucket（邮件测试） ----
INBUCKET_PORT=9000

# ---- Analytics ----
LOGFLARE_API_KEY=your-logflare-key
