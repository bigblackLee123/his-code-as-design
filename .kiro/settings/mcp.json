{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "disabled": false,
      "autoApprove": [
        "take_screenshot",
        "resize_page",
        "navigate_page",
        "take_snapshot",
        "lighthouse_audit",
        "click",
        "wait_for",
        "fill_form",
        "evaluate_script",
        "fill",
        "list_pages",
        "new_page",
        "list_console_messages",
        "get_console_message",
        "list_network_requests"
      ]
    }
  }
}